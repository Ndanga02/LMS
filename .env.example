# ─── Authentication ───────────────────────────
# Generate with: openssl rand -hex 32
AUTH_SECRET=change-me-to-a-random-64-char-hex-string
AUTH_URL=http://localhost:3000

# ─── Database ─────────────────────────────────
# Supabase Postgres (transaction pooler for app queries)
DATABASE_URL=postgresql://user:password@host:6543/postgres?pgbouncer=true
# Supabase Postgres (session pooler for migrations)
DIRECT_URL=postgresql://user:password@host:5432/postgres

# ─── Supabase ─────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# ─── Email (Resend) ───────────────────────────
RESEND_API_KEY=re_xxxxx

# ─── OAuth ────────────────────────────────────
AUTH_GITHUB_CLIENT_ID=your-github-client-id
AUTH_GITHUB_CLIENT_SECRET=your-github-client-secret
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── Super Admin ──────────────────────────────
SUPER_ADMIN_EMAIL=admin@example.com

# ─── Media (Mux) ──────────────────────────────
MUX_TOKEN_ID=your-mux-token-id
MUX_TOKEN_SECRET=your-mux-token-secret

# ─── Redis (Upstash) ──────────────────────────
# Get these from your Upstash console → REST API
UPSTASH_REDIS_REST_URL=https://your-region.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-rest-token

# ─── Internal API secret ──────────────────────
# Shared secret for internal service-to-service calls
INTERNAL_API_SECRET=change-me-to-a-random-string

# ─── Cloudflare R2 (S3-compatible file storage) ──
# Create an API token with read/write access from Cloudflare Dashboard → R2 → API Tokens
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key
R2_BUCKET_NAME=lms-files
R2_PUBLIC_URL=https://pub-xxxxx.r2.dev
