{
  "name": "lms",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "docker compose --profile test up -d testdb && vitest run --config vitest.integration.config.ts; docker compose --profile test down",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "db:test": "tsx --env-file=.env scripts/test-db.ts",
    "db:seed": "tsx --env-file=.env prisma/seed.ts",
    "postinstall": "prisma generate && echo 'Run `npx playwright install --with-deps` manually for E2E tests'"
  },
  "prisma": {
    "seed": "tsx --env-file=.env prisma/seed.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@aws-sdk/client-s3": "^3.1075.0",
    "@dnd-kit/core": "^6.3.1",
